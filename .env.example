# Hermes Anywhere — environment variables.
#
# Copy to .env, fill in values, chmod 600.
# NEVER commit .env to git. NEVER paste values in chat, logs, or shared terminals.
#
# When deploying via Terraform, these values are templated into the VM's .env
# at boot via cloud-init. See terraform/<provider>/terraform.tfvars.example.

# =============================================================================
# Hermes image version (Docker Hub tag)
# =============================================================================
# `latest` is the default — `make install` / `make update` always run
# `docker compose pull` so this resolves to the current digest at deploy time.
# To pin a specific digest or sha-<commit> tag for reproducibility, set it here.
HERMES_VERSION=latest

# Where the dashboard binds. 0.0.0.0 for cloud VMs (firewall gates access),
# 127.0.0.1 for local-only setups.
DASHBOARD_BIND=0.0.0.0

# =============================================================================
# Model — pick anything OpenRouter offers. Default is a free slug so a fresh
# clone costs $0; bump to a paid slug if you want stronger output.
# =============================================================================
# To enforce free-only operation, leave the model on a `:free` slug AND keep
# `hermes fallback list` empty (or also free-only). See docs/MODEL_SELECTION.md.
HERMES_MODEL=openai/gpt-oss-120b:free
HERMES_INFERENCE_PROVIDER=openrouter

# =============================================================================
# LLM providers — at least one is required.
# =============================================================================

# OpenRouter — recommended. Pay-as-you-go with free model slugs (`:free`).
# Get a key at https://openrouter.ai/keys; SET A SPENDING CAP.
# A one-time $10 top-up raises free-model rate limits from 50/day → 1,000/day.
OPENROUTER_API_KEY=

# Anthropic direct API key (optional).
# ANTHROPIC_API_KEY=

# Google AI Studio / Gemini (optional).
# GOOGLE_API_KEY=

# NVIDIA NIM (optional).
# NVIDIA_API_KEY=

# =============================================================================
# Telegram gateway (optional — required only if using Telegram messaging)
# =============================================================================

# Bot token from @BotFather → /newbot.
# TELEGRAM_BOT_TOKEN=

# Comma-separated numeric Telegram user IDs from @userinfobot. MANDATORY if
# TELEGRAM_BOT_TOKEN is set — without it the bot accepts messages from anyone.
# TELEGRAM_ALLOWED_USERS=
